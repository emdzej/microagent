{
  "name": "microagent",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "chat": "node packages/cli/dist/bin.js chat",
    "wizard": "node packages/cli/dist/bin.js config",
    "serve": "node packages/cli/dist/bin.js serve",
    "ui": "node packages/cli/dist/bin.js ui",
    "dev:web": "pnpm --filter @microagent/web dev",
    "dev:server": "node packages/cli/dist/bin.js serve"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
