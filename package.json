{
  "name": "microagent",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "chat": "node packages/cli/dist/bin.js chat",
    "wizard": "node packages/cli/dist/bin.js config",
    "serve": "node packages/cli/dist/bin.js serve",
    "ui": "node packages/cli/dist/bin.js ui",
    "dev:web": "pnpm --filter @microagent/web dev",
    "dev:server": "node packages/cli/dist/bin.js serve"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.2"
  }
}
